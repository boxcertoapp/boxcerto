{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "Permissions-Policy", "value": "geolocation=(), microphone=(), camera=()" }
      ]
    },
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate" }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate" }
      ]
    },
    {
      "source": "/assets/:path*",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/screenshots/:file*",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=2592000, stale-while-revalidate=86400" }
      ]
    },
    {
      "source": "/mockup01:suffix.webp",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=2592000, stale-while-revalidate=86400" }
      ]
    },
    {
      "source": "/logo.svg",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=2592000, stale-while-revalidate=86400" }
      ]
    },
    {
      "source": "/(lp|lp2|lpsistema-para-oficina-pequena|lpboxcerto-vs-planilha|lporcamento-online-oficina|lpdiagnostico|lpquizdiagnostico|quizdiagnostico|lpoficina|sistema-para-oficina-mecanica|programa-para-oficina-mecanica|ordem-de-servico-oficina-mecanica|orcamento-whatsapp-oficina|controle-estoque-oficina|modelo-orcamento-oficina-mecanica-gratis|planilha-estoque-pecas-oficina-gratis|calculadora-mao-de-obra-oficina-mecanica|checklist-revisao-veicular-oficina-gratis|mensagem-cobrar-retorno-orcamento-whatsapp).html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/lp",                             "destination": "/lp.html" },
    { "source": "/lp2",                            "destination": "/lp2.html" },
    { "source": "/lpsistema-para-oficina-pequena", "destination": "/lpsistema-para-oficina-pequena.html" },
    { "source": "/lpboxcerto-vs-planilha",         "destination": "/lpboxcerto-vs-planilha.html" },
    { "source": "/lporcamento-online-oficina",     "destination": "/lporcamento-online-oficina.html" },
    { "source": "/lpdiagnostico",                  "destination": "/lpdiagnostico.html" },
    { "source": "/quizdiagnostico",                "destination": "/quizdiagnostico.html" },
    { "source": "/lpquizdiagnostico",              "destination": "/lpquizdiagnostico.html" },
    { "source": "/lpoficina",                      "destination": "/lpoficina.html" },
    { "source": "/planilha-os-oficina-mecanica-gratis", "destination": "/planilha-os-oficina-mecanica-gratis.html" },
    { "source": "/sistema-para-oficina-mecanica", "destination": "/sistema-para-oficina-mecanica.html" },
    { "source": "/programa-para-oficina-mecanica", "destination": "/programa-para-oficina-mecanica.html" },
    { "source": "/ordem-de-servico-oficina-mecanica", "destination": "/ordem-de-servico-oficina-mecanica.html" },
    { "source": "/orcamento-whatsapp-oficina", "destination": "/orcamento-whatsapp-oficina.html" },
    { "source": "/controle-estoque-oficina", "destination": "/controle-estoque-oficina.html" },
    { "source": "/modelo-orcamento-oficina-mecanica-gratis", "destination": "/modelo-orcamento-oficina-mecanica-gratis.html" },
    { "source": "/calculadora-mao-de-obra-oficina-mecanica", "destination": "/calculadora-mao-de-obra-oficina-mecanica.html" },
    { "source": "/planilha-fluxo-caixa-oficina-mecanica-gratis", "destination": "/planilha-fluxo-caixa-oficina-mecanica-gratis.html" },
    { "source": "/planilha-estoque-pecas-oficina-gratis", "destination": "/planilha-estoque-pecas-oficina-gratis.html" },
    { "source": "/checklist-revisao-veicular-oficina-gratis", "destination": "/checklist-revisao-veicular-oficina-gratis.html" },
    { "source": "/mensagem-cobrar-retorno-orcamento-whatsapp", "destination": "/mensagem-cobrar-retorno-orcamento-whatsapp.html" },
    { "source": "/blog",                           "destination": "/blog/index.html" },
    { "source": "/blog/guias-oficina-mecanica",     "destination": "/blog/guias-oficina-mecanica.html" },
    { "source": "/blog/categoria/:cat",             "destination": "/blog/categoria/:cat.html" },
    { "source": "/blog/planilha-ordem-de-servico-mecanica-gratis", "destination": "/blog/planilha-ordem-de-servico-mecanica-gratis.html" },
    { "source": "/blog/sistema-para-oficina-mecanica",             "destination": "/blog/sistema-para-oficina-mecanica.html" },
    { "source": "/blog/orcamento-oficina-whatsapp",                "destination": "/blog/orcamento-oficina-whatsapp.html" },
    { "source": "/blog/controle-estoque-pecas-oficina",            "destination": "/blog/controle-estoque-pecas-oficina.html" },
    { "source": "/blog/software-ordem-de-servico-mecanica",        "destination": "/blog/software-ordem-de-servico-mecanica.html" },
    { "source": "/blog/como-calcular-mao-de-obra-oficina-mecanica", "destination": "/blog/como-calcular-mao-de-obra-oficina-mecanica.html" },
    { "source": "/blog/fluxo-de-caixa-oficina-mecanica",            "destination": "/blog/fluxo-de-caixa-oficina-mecanica.html" },
    { "source": "/blog/como-organizar-oficina-mecanica-pequena",    "destination": "/blog/como-organizar-oficina-mecanica-pequena.html" },
    { "source": "/blog/checklist-revisao-veicular-oficina",         "destination": "/blog/checklist-revisao-veicular-oficina.html" },
    { "source": "/blog/como-evitar-calote-oficina-mecanica",        "destination": "/blog/como-evitar-calote-oficina-mecanica.html" },
    { "source": "/blog/como-ser-mecanico-automotivo",               "destination": "/blog/como-ser-mecanico-automotivo.html" },
    { "source": "/blog/como-aumentar-faturamento-oficina-mecanica",  "destination": "/blog/como-aumentar-faturamento-oficina-mecanica.html" },
    { "source": "/blog/:slug",                       "destination": "/blog/:slug.html" },
    { "source": "/((?!api/).*)",                   "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/cron-emails",
      "schedule": "0 10 * * *"
    }
  ]
}
